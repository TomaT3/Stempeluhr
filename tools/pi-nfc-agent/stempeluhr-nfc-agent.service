[Unit]
Description=Stempeluhr NFC agent
After=network-online.target pcscd.service
Wants=network-online.target pcscd.service

[Service]
Type=simple
User=stempeluhr
Group=stempeluhr
ExecStart=/usr/bin/python3 /opt/stempeluhr-nfc-agent/stempeluhr_nfc_agent.py --config /etc/stempeluhr-nfc-agent/config.json
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadOnlyPaths=/opt/stempeluhr-nfc-agent /etc/stempeluhr-nfc-agent

[Install]
WantedBy=multi-user.target
